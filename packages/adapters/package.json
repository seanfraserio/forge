{
  "name": "@openforge-ai/adapters",
  "version": "0.1.0",
  "description": "LLM provider adapters for Forge agent infrastructure",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/seanfraserio/forge.git",
    "directory": "packages/adapters"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist"],
  "keywords": ["forge", "ai", "agents", "adapters", "anthropic", "openai"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openforge-ai/sdk": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
